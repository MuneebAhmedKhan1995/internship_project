{
    "version": 2,
    "builds": [
        {
            "src": "index.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "index.js",
            "methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS", "PATCH"]
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Access-Control-Allow-Origin",
                    "value": "https://mern-project-e-commerce-store.vercel.app"
                },
                {
                    "key": "Access-Control-Allow-Credentials",
                    "value": "true"
                },
                {
                    "key": "Access-Control-Allow-Methods",
                    "value": "GET, POST, PUT, DELETE, OPTIONS, PATCH"
                },
                {
                    "key": "Access-Control-Allow-Headers",
                    "value": "Content-Type, Authorization, X-Requested-With"
                }
            ]
        }
    ],
    "env": {
        "MONGO_URI": "mongodb+srv://dbuser:admin@cluster0.whqvfjl.mongodb.net/Ecommerce-Store?retryWrites=true&w=majority&appName=Cluster0",
        "JWT_SECRET": "ECOM123",
        "PORT": "3000"
    }
}